{
	"name": "uc5-desktop-mod1-ipc",
	"version": "1.0.0",
	"main": "dist-electron/main.js",
	"description": "Projeto de referência: exercícios IPC com Electron + Vite + TypeScript",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build && electron-builder",
		"start": "vite",
		"pull": "git pull origin main && npm install",
		"push": "git status && git add . && git commit -m 'Interface for tables' && git push origin main",
		"generate-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\""
	},
	"dependencies": {
		"pg": "^8.12.0",
		"dotenv": "^16.4.5"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"electron": "^42.6.0",
		"electron-builder": "^26.15.3",
		"typescript": "^5.4.5",
		"vite": "^8.1.3",
		"vite-plugin-electron": "^1.1.0",
		"vite-plugin-electron-renderer": "^1.0.0"
	},
	"build": {
		"appId": "io.github.thalsime.uc5desktop",
		"productName": "UC5Desktop",
		"win": {
			"target": "nsis",
			"requestedExecutionLevel": "asInvoker"
		},
		"nsis": {
			"oneClick": true,
			"perMachine": false,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true
		}
	}
}
